/*
========================================================================================
    Nextflow config file for nf-test
========================================================================================
    Includes the project root `nextflow.config` so Apptainer settings and every
    process-level `container` directive in `modules/` behave like production: each
    process runs in the image declared on that process (no global test image).

    Local execution is forced so nf-test never uses the SLURM executor from the
    main config.

    Processes without a `container` line (e.g. UNIQUE_ID) still run on the host
    Python when Apptainer is enabled; Nextflow only wraps tasks that declare a
    container.
*/

includeConfig '../nextflow.config'

process {
    executor = 'local'
    withName: 'RFDIFFUSION' {
        // Deterministic runs for nf-test; override in a per-run config if needed
        ext.args = 'inference.deterministic=true'
    }
}

executor {
    name = 'local'
}
