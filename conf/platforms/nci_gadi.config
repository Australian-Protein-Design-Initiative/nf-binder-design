/*
 * NCI Gadi HPC configuration for PBS Pro
 * Based on nf-core NCI Gadi config: https://nf-co.re/configs/nci_gadi/
 */

params {
    config_profile_description = 'NCI Gadi HPC profile'
    config_profile_url = 'https://opus.nci.org.au/display/Help/Gadi+User+Guide'
    project = System.getenv("PROJECT")
}

// PBS Pro executor settings
// Submit up to 300 concurrent jobs (Gadi exec max)
// pollInterval and queueStatInterval of every 5 minutes
// submitRateLimit of 20 per minute
executor {
    $pbspro {
        queueSize = 300
        pollInterval = '5 min'
        queueStatInterval = '5 min'
        submitRateLimit = '20 min'
    }
}

// Helper function for GPU queue selection with fallback
// First attempt uses gpuvolta, retry uses gpuhopper
def gpuQueue(task) {
    return task.attempt == 1 ? 'gpuvolta' : 'gpuhopper'
}

process {
    executor = 'pbspro'
    project = params.project
    storage = "scratch/${params.project}+gdata/${params.project}"
    module = 'singularity'
    cache = 'lenient'
    stageInMode = 'symlink'
    beforeScript = 'module load singularity'

    // Default error strategy - retry once on failure
    errorStrategy = 'retry'
    maxRetries = 1
    scratch = true
    cleanup = true

    // Local executor processes (no PBS submission)
    withName: UNIQUE_ID {
        executor = 'local'
    }

    withName: GET_CONTIGS {
        executor = 'local'
    }

    withName: RENUMBER_RESIDUES {
        executor = 'local'
    }

    withName: FILTER_DESIGNS {
        executor = 'local'
    }

    withName: RFD3_FILTER_DESIGNS {
        executor = 'local'
    }

    withName: AF2IG_SCORE_FILTER {
        executor = 'local'
    }

    withName: COMBINE_SCORES {
        executor = 'local'
    }

    withName: 'COMBINE_RFD3_SCORES' {
        executor = 'local'
    }

    withName: CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        executor = 'local'
    }

    withName: BOLTZ_PULLDOWN_REPORTING {
        executor = 'local'
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        executor = 'local'
    }

    withName: BOLTZGEN_MERGE {
        queue = 'normalbw'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    // GPU processes - gpuvolta with fallback to gpuhopper
    // clusterOptions closure dynamically builds PBS -l from cpus/memory directives
    withName: RFDIFFUSION {
        queue = { gpuQueue(task) }
        time = 2.hours
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: RFDIFFUSION_PARTIAL {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: GENERATE_RFD3_CONFIG {
        executor = 'local'
    }

    withName: RFDIFFUSION3 {
        queue = { gpuQueue(task) }
        time = 2.hours
        cpus = 2
        memory = 32.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: MPNN {
        queue = 'normalbw'
        time = 30.minutes
        memory = '4.GB'
        cpus = 1
    }

    withName: ROSETTAFOLD3 {
        queue = { gpuQueue(task) }
        time = { 15.minutes * Math.max(1, (params.rf3_batch_size ?: 1) as int) }
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: RFD3_RMSD {
        executor = 'local'
    }

    withName: AF2_INITIAL_GUESS {
        queue = { gpuQueue(task) }
        time = 2.hours
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZ {
        queue = { gpuQueue(task) }
        time = 1.hours
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZ_COMPARE_COMPLEX {
        queue = { gpuQueue(task) }
        time = 2.hours
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZ_COMPARE_BINDER_MONOMER {
        queue = { gpuQueue(task) }
        time = 1.hours
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BINDCRAFT {
        queue = { gpuQueue(task) }
        time = 2.hours
        cpus = 12
        memory = 16.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_DESIGN {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 16.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 8.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_FOLDING {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 16.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 16.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_ANALYSIS {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 64.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    withName: BOLTZGEN_FILTERING {
        queue = { gpuQueue(task) }
        time = 30.minutes
        cpus = 12
        memory = 4.GB
        clusterOptions = { "-l ncpus=${task.cpus},mem=${task.memory.toGiga()}GB,ngpus=1" }
    }

    // CPU-only processes
    // Use normalbw (Broadwell) for jobs needing ≤128 GB - cheaper at 1.25 SU vs 2 SU
    // Use normal (Cascade Lake) for jobs needing >128 GB and ≤190 GB
    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        queue = 'normalbw'
        time = 30.minutes
        memory = '4.GB'
        cpus = 1
    }

    withName: MMSEQS_COLABFOLDSEARCH {
        queue = 'normalbw'
        time = 4.hours
        memory = '64.GB'
        cpus = 14  // Half a Broadwell node (28 CPUs/node)
    }

    // FoldSeek processes
    withName: FOLDSEEK_DOWNLOAD_DB {
        executor = 'local'
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        time = 30.minutes
        memory = '4g'
        cpus = 2
    }

    withName: FOLDSEEK_LOCAL_SEARCH {
        time = 4.hours
        memory = '16g'
        cpus = 8
    }

    withName: FOLDSEEK_REMOTE_SEARCH {
        executor = 'local'
        time = 2.hours
        memory = '4g'
        cpus = 1
    }

    withName: FOLDSEEK_DOWNLOAD_CATH_NAMES {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
        errorStrategy = 'ignore'
    }

    withName: FOLDSEEK_ANNOTATE_CATH {
        time = 30.minutes
        memory = '4g'
        cpus = 2
        errorStrategy = 'ignore'
    }
}

// Singularity settings for Gadi
// NCI Gadi provides a 'singularity' module (Apptainer with compatibility wrapper)
// Explicitly disable apptainer to avoid conflicts with pipeline defaults
singularity {
    enabled = true
    autoMounts = true
    pullTimeout = 3.hours
    // --nv to enable NVIDIA GPU support
    // We add -B \$HOME to ensure the home directory is available
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME"
}

apptainer {
    enabled = false
}

// Write custom trace file with outputs required for SU calculation
def trace_timestamp = new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')
trace {
    enabled = true
    overwrite = false
    file = "./gadi-trace-${trace_timestamp}.txt"
    fields = 'name,status,exit,duration,realtime,cpus,%cpu,memory,%mem,rss'
}
