/*
 * This is a configuration specific to users of the Pawsey Setonix GPU cluster.
 */

/* NOTES:

Containers go in /software/projects/${PAWSEY_PROJECT}/${USER}/.nextflow_singularity
(ie $$MYSOFTWARE/.nextflow_singularity)

eg: /software/projects/pawsey1343/aperry/.nextflow_singularity

Pawsey Sentonix SLURM Partitions: https://pawsey.atlassian.net/wiki/spaces/US/pages/51925964/Job+Scheduling#Slurm-partitions
Pawsey Sentonx GPU jobs (note well): https://pawsey.atlassian.net/wiki/spaces/US/pages/51928618/Setonix+GPU+Partition+Quick+Start
Singularity on Pawsey: https://pawsey.atlassian.net/wiki/spaces/US/pages/51925894/Singularity
Nextflow on Pawsey: https://pawsey.atlassian.net/wiki/spaces/US/pages/51925914/Nextflow
Workflow nodes: https://pawsey.atlassian.net/wiki/spaces/US/pages/286097469/How+to+Run+Workflows+on+the+Workflow+Nodes

NOTE: GPU jobs must be submitted with the `-gpu` suffix on the account name, eg `--account=pawsey1343-gpu` (**not** `pawsey1343`)

- Other Pawsey docs (not directly relevant, but used to help build the containers): 
  - https://pawsey.atlassian.net/wiki/spaces/US/pages/613089393/Using+ProteinMPNN+on+AMD+GPUs
  - https://pawsey.atlassian.net/wiki/spaces/US/pages/51931230/PyTorch

*/

params.slurm_account = false

def random_choice(choices) {
    return choices[new Random().nextInt(choices.size())]
}

// Singularity options for AMD GPU processes on Setonix (MI250X). Not for CUDA-only containers.
def rocm_container_options = '--rocm -B /opt/rocm/lib/rocblas/library --env ROCBLAS_TENSILE_LIBPATH=/opt/rocm/lib/rocblas/library'

executor {
    $slurm {
        queueSize = 200
        pollInterval = '30 sec'
        queueStatInterval = '10m'
    }
}

process {
    executor = 'slurm'
    stageInMode = 'symlink'
    errorStrategy = 'retry'
    maxRetries = 1
    cache = 'lenient'

    withName: UNIQUE_ID {
        executor = 'local'
    }

    withName: GET_CONTIGS {
        //container = params.containers.get_contigs
        executor = 'local'
    }

    withName: RENUMBER_RESIDUES {
        //container = params.containers.renumber_residues
        executor = 'local'
    }

    withName: FILTER_DESIGNS {
        executor = 'local'
    }

    withName: AF2IG_SCORE_FILTER {
        executor = 'local'
    }

    withName: COMBINE_SCORES {
        //container = params.containers.combine_scores
        executor = 'local'
    }

    withName: RFDIFFUSION {
        //container = params.containers.rfdiffusion
        //container = 'quay.io/pawsey/rfdiffusion:rocm6.4'
        container = 'https://bioinformatics.erc.monash.edu/home/andrewperry/containers/quay.io-pawsey-rfdiffusion-rocm6.4.img'
        containerOptions = rocm_container_options

        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 30.minutes
        accelerator = 1
    }

    withName: RFDIFFUSION_PARTIAL {
        //container = params.containers.rfdiffusion
        //container = 'quay.io/pawsey/rfdiffusion:rocm6.4'
        container = 'https://bioinformatics.erc.monash.edu/home/andrewperry/containers/quay.io-pawsey-rfdiffusion-rocm6.4.img'
        containerOptions = rocm_container_options

        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes
        accelerator = 1
    }

    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        //container = params.containers.dl_binder_design_proteinmpnn
        //container = '/scratch/pawsey1343/aperry/containers/dl_binder_design-rocm-latest.sif'
        container = 'https://bioinformatics.erc.monash.edu/home/andrewperry/containers/ghcr.io-australian-protein-design-initiative-containers-proteinmpnn_dl_binder_design-rocm.img'
        containerOptions = rocm_container_options

        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 15.minutes
    }

    withName: AF2_INITIAL_GUESS {
        //container = params.containers.af2_initial_guess
        //container = '/scratch/pawsey1343/aperry/containers/dl_binder_design-rocm-latest.sif'
        container = 'https://bioinformatics.erc.monash.edu/home/andrewperry/containers/dl_binder_design-rocm-latest.sif'
        containerOptions = rocm_container_options
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 15.minutes   
    }

    withName: BINDCRAFT_SCORING_AF2IG {
        // CUDA BindCraft image (PyRosetta only); do not use rocm_container_options
        //executor = 'local'
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes   
    }

    withName: CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        executor = 'local'
    }

    withName: BOLTZ_PULLDOWN_REPORTING {
        executor = 'local'
    }

    withName: MMSEQS_COLABFOLDSEARCH {
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 4.hours
        memory = '64g'
        cpus = 16

        //memory = '128g' // '360g'
        //cpus = 24       // 48
        // Load index into RAM
        //ext.args = "--db-load-mode 2"
    }

    withName: BOLTZ {
        containerOptions = rocm_container_options
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
    }

    withName: BOLTZ_COMPARE_COMPLEX {
        containerOptions = rocm_container_options
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
    }

    withName: BOLTZ_COMPARE_BINDER_MONOMER {
        containerOptions = rocm_container_options
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        executor = 'local'
    }

    withName: BINDCRAFT {
        containerOptions = rocm_container_options
        accelerator = 1
        time = 2.hours

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_DESIGN {
        containerOptions = rocm_container_options
        accelerator = 1
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        containerOptions = rocm_container_options
        accelerator = 1
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_FOLDING {
        containerOptions = rocm_container_options
        accelerator = 1
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        containerOptions = rocm_container_options
        accelerator = 1
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_MERGE {
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_ANALYSIS {
        containerOptions = rocm_container_options
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: BOLTZGEN_FILTERING {
        containerOptions = rocm_container_options
        time = 30.minutes
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    // FoldSeek processes
    withName: FOLDSEEK_DOWNLOAD_DB {
        executor = 'local'
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes
    }

    withName: FOLDSEEK_LOCAL_SEARCH {
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 4.hours
    }

    withName: FOLDSEEK_REMOTE_SEARCH {
        executor = 'local'
        time = 2.hours
        memory = '4g'
        cpus = 1
    }

    withName: FOLDSEEK_DOWNLOAD_CATH_NAMES {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
        errorStrategy = 'ignore'
    }

    withName: FOLDSEEK_ANNOTATE_CATH {
        containerOptions = rocm_container_options
        clusterOptions = '--gres=gpu:1 --partition=gpu --qos=normal --nodes=1' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes
        errorStrategy = 'ignore'
    }
}

apptainer {
    enabled = false
}

singularity {
    enabled = true
    autoMounts = true
    pullTimeout = 3.hours
    cacheDir = "$MYSOFTWARE/.nextflow_singularity"
    
    // ROCm options are per-process via rocm_container_options (see process.withName above)
    runOptions = "--cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /scratch"
    // LD_LIBRARY_PATH / LD_PRELOAD are deliberately NOT whitelisted: on Setonix
    // they leak host ROCm paths (eg libamdhip64.so.6) into containers that
    // don't have those libs bind-mounted, breaking even /bin/bash inside the
    // container. Use per-process containerOptions if a container needs them.
    envWhitelist = ['BOLTZ_CACHE', 'SINGULARITY_TMPDIR', 'SINGULARITY_BINDPATH', 'ROCBLAS_TENSILE_LIBPATH', 'SINGULARITYENV_ROCBLAS_TENSILE_LIBPATH']
}
