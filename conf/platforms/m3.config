/*
 * This is a configuration specific to users of the M3 / MASSIVE HPC cluster at Monash University.
 */

includeConfig "${projectDir}/conf/platforms/monash_containers.config"

params.slurm_account = false

def account_option = (params.slurm_account ? " --account=${params.slurm_account} " : '')

def random_choice(choices) {
    return choices[new Random().nextInt(choices.size())]
}

executor {
    $slurm {
        queueSize = 200
        pollInterval = '30 sec'
        queueStatInterval = '10m'
    }
}

process {
    executor = 'slurm'
    stageInMode = 'symlink'
    errorStrategy = 'retry'
    maxRetries = 1
    cache = 'lenient'

    withName: UNIQUE_ID {
        executor = 'local'
    }

    withName: GET_CONTIGS {
        //container = params.containers.get_contigs
        executor = 'local'
    }

    withName: RENUMBER_RESIDUES {
        //container = params.containers.renumber_residues
        executor = 'local'
    }

    withName: FILTER_DESIGNS {
        executor = 'local'
    }

    withName: RFD3_FILTER_DESIGNS {
        executor = 'local'
    }

    withName: 'COMBINE_RFD3_SCORES' {
        executor = 'local'
    }

    withName: AF2IG_SCORE_FILTER {
        executor = 'local'
    }

    withName: COMBINE_SCORES {
        //container = params.containers.combine_scores
        executor = 'local'
    }

    withName: RFDIFFUSION {
        //container = params.containers.rfdiffusion

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // H100-80G
        // clusterOptions = "--gres=gpu:1 --partition=m3h --qos=m3h" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = '--gres=gpu:1 --partition=bdi --qos=bdiq' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 2.hours
        accelerator = 1

        memory = '64g'
        cpus = 16
    }

    withName: RFDIFFUSION_PARTIAL {
        //container = params.containers.rfdiffusion

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // H100-80G
        // clusterOptions = "--gres=gpu:1 --partition=m3h --qos=m3h" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = '--gres=gpu:1 --partition=bdi --qos=bdiq' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 30.minutes
        accelerator = 1
        memory = '64g'
        cpus = 16
    }

    withName: GENERATE_RFD3_CONFIG {
        executor = 'local'
    }

    withName: RFDIFFUSION3 {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 2.hours
        memory = '32g'
        cpus = 2
    }

    withName: MPNN {
        clusterOptions = '--partition=comp --qos=shortq' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    withName: ROSETTAFOLD3 {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = { 15.minutes * Math.max(1, (params.rf3_batch_size ?: 1) as int) }
        memory = '64g'
        cpus = 2
    }

    withName: RFD3_RMSD {
        executor = 'local'
    }

    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        //container = params.containers.dl_binder_design_proteinmpnn

        // CPU only
        // clusterOptions = "--partition=genomics --qos=genomics" + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        clusterOptions = '--partition=comp --qos=shortq' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 30.minutes

        memory = '4g'
        cpus = 1
    }

    withName: AF2_INITIAL_GUESS {
        //container = params.containers.af2_initial_guess
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // H100-80G
        //clusterOptions = '--gres=gpu:1 --partition=m3h --qos=m3h' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 2.hours

        memory = '64g'
        cpus = 16
    }

    withName: ALPHAFOLD2_JACKHMMER_MSA {
        // comp partition - do NOT use --qos=shortq, it caps at 30 min and the
        // full_dbs MSA/feature-generation stage needs hours for large targets.
        clusterOptions = '--partition=comp' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 8.hours
        memory = '64g'
        cpus = 8
    }

    withName: ALPHAFOLD2 {
        accelerator = 1
        // No L40S exclusion here - unlike the older CUDA-11 AF2 containers
        // elsewhere in this pipeline, this CUDA-12 custom build requires
        // L40S-class (or newer) GPUs; see plans/on-this-new-branch-groovy-moonbeam.md.
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 2.hours
        memory = '64g'
        cpus = 4
    }

    withName: CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        executor = 'local'
    }

    withName: BOLTZ_PULLDOWN_REPORTING {
        executor = 'local'
    }

    withName: MMSEQS_COLABFOLDSEARCH {
        // comp partition
        clusterOptions = '--partition=comp' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 4.hours
        // 128g: local colabfold_search over the indexed uniref30+envdb DBs
        // estimates ~95g for the prefilter step (verified 2026-07-18). Remote
        // mode (--use_remote_server) needs far less, but this is the safe ceiling.
        memory = '128g'
        cpus = 16

    // genomics partition
    //clusterOptions = "--partition=genomics --qos=genomics" + (params.slurm_account ? " --account=${params.slurm_account} " : "")
    //time = 4.hours
    //memory = '128g' // '360g'
    //cpus = 24       // 48
    // Load index into RAM
    //ext.args = "--db-load-mode 2"
    }

    withName: BOLTZ {
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
        memory = '64g'
        cpus = 2
    }

    withName: 'BOLTZ_PULLDOWN:BOLTZ' {
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
        memory = '64g'
        cpus = 2
    }


    withName: BOLTZ_COMPARE_COMPLEX {
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 2.hours
        memory = '64g'
        cpus = 2
    }

    withName: BOLTZ_COMPARE_BINDER_MONOMER {
        accelerator = 1

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        //clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        time = 1.hours
        memory = '64g'
        cpus = 2
    }

    // fold.nf (see plans/fold-nf-multi-method-folding.md) - new processes only;
    // MMSEQS_COLABFOLDSEARCH, ALPHAFOLD2*, BOLTZ selectors above are reused as-is.
    withName: COLABFOLD_A3M_TO_AF2_MSAS {
        executor = 'local'
    }

    withName: AF2_MSAS_TO_A3M {
        executor = 'local'
    }

    withName: FOLD_CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: FOLD_PARSE_BOLTZ_CONFIDENCE {
        executor = 'local'
    }

    withName: ENGENS_STAGE_STRUCTURE {
        executor = 'local'
    }

    withName: ENGENS {
        // CPU-only Quarto + EnGens report; no GPU.
        clusterOptions = '--partition=comp' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 2.hours
        memory = '16g'
        cpus = 4
    }

    withName: 'BOLTZ_FOLD:BOLTZ' {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 1.hours
        memory = '64g'
        cpus = 2
    }

    withName: GENERATE_RF3_FOLD_INPUT {
        executor = 'local'
    }

    withName: RF3_FOLD {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = { 15.minutes * Math.max(1, (params.rf3_batch_size ?: params.n_predictions ?: 5) as int) }
        memory = '64g'
        cpus = 2
    }

    withName: GENERATE_PROTENIX_INPUT {
        executor = 'local'
    }

    // See nextflow.config's matching selector comment - PROTENIX_FOLD_PROCESS
    // is the include alias for modules/local/protenix/protenix_fold.nf's
    // PROTENIX_FOLD process (aliased to avoid colliding with the wrapping
    // PROTENIX_FOLD subworkflow name).
    withName: PROTENIX_FOLD_PROCESS {
        accelerator = 1
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')
        time = 1.hours
        memory = '64g'
        cpus = 2
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        executor = 'local'
    }

    withName: BINDCRAFT {
        accelerator = 1
        time = 2.hours
        memory = '16g'
        cpus = 2

        // GPU partition
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account} " : '')

        // BDI: A100/A40
        // clusterOptions = "--gres=gpu:1 --partition=bdi --qos=bdiq" + (params.slurm_account ? " --account=${params.slurm_account} " : '')
    }

    withName: /^(GERMINAL|GERMINAL_PROCESS)$/ {
        accelerator = 1
        time = 24.hours
        memory = '48g'
        cpus = 8
        clusterOptions = '--gres=gpu:1 --partition=gpu' + (params.slurm_account ? " --account=${params.slurm_account}" : '')
    }

    withName: GERMINAL_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_DESIGN {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '8g'
        cpus = 2
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    withName: BOLTZGEN_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    withName: BOLTZGEN_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_ANALYSIS {
        time = 30.minutes
        memory = '64g'
        cpus = 8
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    withName: BOLTZGEN_FILTERING {
        time = 30.minutes
        memory = '4g'
        cpus = 1
        clusterOptions = "--gres=gpu:1 --partition=gpu ${account_option}"
    }

    // FoldSeek processes
    withName: FOLDSEEK_DOWNLOAD_DB {
        executor = 'local'
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        time = 30.minutes
        memory = '4g'
        cpus = 2
    }

    withName: FOLDSEEK_LOCAL_SEARCH {
        time = 4.hours
        memory = '16g'
        cpus = 8
    }

    withName: FOLDSEEK_REMOTE_SEARCH {
        executor = 'local'
        time = 2.hours
        memory = '4g'
        cpus = 1
    }

    withName: FOLDSEEK_DOWNLOAD_CATH_NAMES {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
        errorStrategy = 'ignore'
    }

    withName: FOLDSEEK_ANNOTATE_CATH {
        time = 30.minutes
        memory = '4g'
        cpus = 2
        errorStrategy = 'ignore'
    }
}

// Apptainer specific settings
apptainer {
    enabled = true
    autoMounts = true
    pullTimeout = 3.hours

    // --nv to enable NVIDIA GPU support    
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /scratch2 -B /fs04"
    // runOptions = "--nv -B /scratch2 -B /fs04 -B /mnt/reference2/alphafold/alphafold_20240229:/app/dl_binder_design/af2_initial_guess/model_weights"
    // -B ${params.models_basepath}:/models
    envWhitelist = ['BOLTZ_CACHE']
}
