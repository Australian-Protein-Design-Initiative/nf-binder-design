/*
 * Spartan HPC (University of Melbourne) — 80GB Nvidia A100 GPUs.
 *
 * Default partition: gpu-a100-short (1 GPU, 4 hour wall limit).
 * For longer GPU jobs (up to 7 days), override: --slurm_gpu_partition gpu-a100
 * and clear the walltime cap: --slurm_gpu_max_walltime false
 *
 * Public GPU partitions do not require a QoS (remove legacy LIEF GPGPU qos settings).
 * https://rcs-knowledge-hub.atlassian.net/wiki/spaces/KB/pages/958365708/Accessing+GPUs
 *
 * Set scratch for Apptainer cache and bind mounts, e.g.:
 *   --slurm_scratch /data/scratch/projects/punim1234
 *
 * Usage: -profile slurm,spartan_a100
 */

includeConfig "${projectDir}/conf/platforms/spartan.config"

params.slurm_gpu_partition = 'gpu-a100-short'
params.slurm_gpu_max_walltime = 4.hours
