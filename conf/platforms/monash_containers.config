/*
 * Container URL overrides so that M3 / MASSIVE users (m3, m3_bdi
 * profiles) pull containers from the Monash Bioinformatics Platform mirror
 * (https://bioinformatics.erc.monash.edu/home/andrewperry/containers/)
 * instead of pulling directly from ghcr.io.
 *
 * Selectors and container tags here should be kept in sync with the
 * `container` directives declared in the corresponding `modules/local/**`
 * (and, in a couple of cases, `workflows/**`) process definitions.
 * See also `get_monash_containers.sh` for pre-fetching these images into the
 * Apptainer cache ahead of a run.
 *
 * NOTE: the following containers used by the pipeline are NOT currently
 * mirrored at the URL above, so no override is defined for them below - they
 * will still be pulled from their original registries when using the m3*
 * profiles:
 *   - SILENT_FROM_PDBS: proteinmpnn_fastrelax:latest
 *   - MMSEQS_COLABFOLDSEARCH: quay.io/nf-core/proteinfold_colabfold:1.1.1
 *   - FOLDSEEK_DOWNLOAD_DB, FOLDSEEK_LOCAL_SEARCH, FOLDSEEK_REMOTE_SEARCH,
 *     FOLDSEEK_DOWNLOAD_CATH_NAMES: quay.io/biocontainers/foldseek:10.941cd33--h5021889_1
 */

def monash_container_base = 'https://bioinformatics.erc.monash.edu/home/andrewperry/containers'

process {
    // rfdiffusion:pytorch2407
    withName: RFDIFFUSION {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_rfdiffusion_pytorch2407.sif"
    }

    withName: RFDIFFUSION_PARTIAL {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_rfdiffusion_pytorch2407.sif"
    }

    // rc-foundry:0.2.0-weights
    withName: RFDIFFUSION3 {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-rc-foundry-0.2.0-weights.img"
    }

    withName: MPNN {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-rc-foundry-0.2.0-weights.img"
    }

    withName: ROSETTAFOLD3 {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-rc-foundry-0.2.0-weights.img"
    }

    // af2_initial_guess:nv-cuda12
    withName: AF2_INITIAL_GUESS {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_af2_initial_guess_nv-cuda12.sif"
    }

    // proteinmpnn_dl_binder_design:latest
    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_proteinmpnn_dl_binder_design_latest.sif"
    }

    // boltz:v2.2.1-2
    withName: BOLTZ {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_boltz_v2.2.1-2.sif"
    }

    withName: 'BOLTZ_PULLDOWN:BOLTZ' {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_boltz_v2.2.1-2.sif"
    }

    withName: BOLTZ_COMPARE_COMPLEX {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_boltz_v2.2.1-2.sif"
    }

    withName: BOLTZ_COMPARE_BINDER_MONOMER {
        container = "${monash_container_base}/ghcr.io_australian-protein-design-initiative_containers_boltz_v2.2.1-2.sif"
    }

    // bindcraft:0366085-nv-cuda120
    withName: BINDCRAFT {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-bindcraft-0366085-nv-cuda120.img"
    }

    withName: BINDCRAFT_SCORING_AF2IG {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-bindcraft-0366085-nv-cuda120.img"
    }

    withName: BINDCRAFT_SCORING_BOLTZ_COMPLEX {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-bindcraft-0366085-nv-cuda120.img"
    }

    // boltzgen:0.3.2
    withName: BOLTZGEN_DESIGN {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_FOLDING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_AFFINITY {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_ANALYSIS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_FILTERING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_CHECK {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    withName: BOLTZGEN_MERGE {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-boltzgen-0.3.2.img"
    }

    // nf-binder-design-utils:0.1.6
    withName: GET_CONTIGS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: RENUMBER_RESIDUES {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: FILTER_DESIGNS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: RFD3_FILTER_DESIGNS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: 'COMBINE_RFD3_SCORES' {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: AF2IG_SCORE_FILTER {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: COMBINE_SCORES {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: BOLTZ_PULLDOWN_REPORTING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: RFD3_RMSD {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: GENERATE_RF3_INPUT_JSON {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: PREPARE_RF3_TEMPLATE {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: RENAME_RF3_TEMPLATE_CHAINS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: BINDCRAFT_REPORTING {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: RMSD4ALL {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: PDB_TO_FASTA {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    withName: TRIM_TO_CONTIGS {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.6.img"
    }

    // nf-binder-design-utils:0.1.5
    withName: FOLDSEEK_ANNOTATE_CATH {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.5.img"
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.5.img"
    }

    withName: GERMINAL_MERGE {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.5.img"
    }

    // germinal:20260611-104bbdd7
    withName: /^(GERMINAL|GERMINAL_PROCESS)$/ {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-germinal-20260611-104bbdd7.img"
    }

    // Defined inline in workflows/boltz_pulldown.nf (still pinned to 0.1.5)
    withName: CREATE_BOLTZ_YAML {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.5.img"
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        container = "${monash_container_base}/ghcr.io-australian-protein-design-initiative-containers-nf-binder-design-utils-0.1.5.img"
    }
}
