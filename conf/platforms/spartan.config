/*
 * Shared Spartan HPC (University of Melbourne) SLURM + Apptainer settings.
 * Included by spartan-a100.config and spartan-l40s.config — do not use directly.
 *
 * https://rcs-knowledge-hub.atlassian.net/wiki/spaces/KB/pages/958365708/Accessing+GPUs
 * https://dashboard.hpc.unimelb.edu.au/software/containers/
 */

params.slurm_account = false
params.slurm_scratch = false
params.slurm_gpu_gres = 'gpu:1'
params.slurm_cpu_partition = 'sapphire'

def account_option = (params.slurm_account ? " --account=${params.slurm_account}" : '')
def gpu_opts = { "--partition=${params.slurm_gpu_partition} --gres=${params.slurm_gpu_gres}${account_option}" }
def cpu_opts = { "--partition=${params.slurm_cpu_partition}${account_option}" }

def capped_gpu_time(duration) {
    if (!params.slurm_gpu_max_walltime) {
        return duration
    }
    return duration > params.slurm_gpu_max_walltime ? params.slurm_gpu_max_walltime : duration
}

def scratch_bind = (params.slurm_scratch ? " -B ${params.slurm_scratch}" : '')

executor {
    $slurm {
        queueSize = 200
        pollInterval = '30 sec'
        queueStatInterval = '10m'
    }
}

process {
    executor = 'slurm'
    stageInMode = 'symlink'
    errorStrategy = 'retry'
    maxRetries = 1
    cache = 'lenient'

    withName: UNIQUE_ID {
        executor = 'local'
    }

    withName: GET_CONTIGS {
        executor = 'local'
    }

    withName: RENUMBER_RESIDUES {
        executor = 'local'
    }

    withName: FILTER_DESIGNS {
        executor = 'local'
    }

    withName: RFD3_FILTER_DESIGNS {
        executor = 'local'
    }

    withName: 'COMBINE_RFD3_SCORES' {
        executor = 'local'
    }

    withName: AF2IG_SCORE_FILTER {
        executor = 'local'
    }

    withName: COMBINE_SCORES {
        executor = 'local'
    }

    withName: RFDIFFUSION {
        clusterOptions = gpu_opts
        time = capped_gpu_time(2.hours)
        accelerator = 1
        memory = '64g'
        cpus = 16
    }

    withName: RFDIFFUSION_PARTIAL {
        clusterOptions = gpu_opts
        time = capped_gpu_time(30.minutes)
        accelerator = 1
        memory = '64g'
        cpus = 16
    }

    withName: GENERATE_RFD3_CONFIG {
        executor = 'local'
    }

    withName: RFDIFFUSION3 {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(2.hours)
        memory = '32g'
        cpus = 2
    }

    withName: MPNN {
        clusterOptions = cpu_opts
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    withName: ROSETTAFOLD3 {
        accelerator = 1
        clusterOptions = gpu_opts
        time = { capped_gpu_time(15.minutes * Math.max(1, (params.rf3_batch_size ?: 1) as int)) }
        memory = '64g'
        cpus = 2
    }

    withName: RFD3_RMSD {
        executor = 'local'
    }

    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        clusterOptions = cpu_opts
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    withName: AF2_INITIAL_GUESS {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(2.hours)
        memory = '64g'
        cpus = 16
    }

    withName: CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        executor = 'local'
    }

    withName: BOLTZ_PULLDOWN_REPORTING {
        executor = 'local'
    }

    withName: MMSEQS_COLABFOLDSEARCH {
        clusterOptions = cpu_opts
        time = 4.hours
        memory = '64g'
        cpus = 16
    }

    withName: BOLTZ {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(1.hours)
        memory = '64g'
        cpus = 2
    }

    withName: 'BOLTZ_PULLDOWN:BOLTZ' {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(1.hours)
        memory = '64g'
        cpus = 2
    }

    withName: BOLTZ_COMPARE_COMPLEX {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(2.hours)
        memory = '64g'
        cpus = 2
    }

    withName: BOLTZ_COMPARE_BINDER_MONOMER {
        accelerator = 1
        clusterOptions = gpu_opts
        time = capped_gpu_time(1.hours)
        memory = '64g'
        cpus = 2
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        executor = 'local'
    }

    withName: BINDCRAFT {
        accelerator = 1
        time = capped_gpu_time(2.hours)
        memory = '16g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: /^(GERMINAL|GERMINAL_PROCESS)$/ {
        accelerator = 1
        time = capped_gpu_time(24.hours)
        memory = '48g'
        cpus = 8
        clusterOptions = gpu_opts
    }

    withName: GERMINAL_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_DESIGN {
        accelerator = 1
        time = capped_gpu_time(30.minutes)
        memory = '16g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        accelerator = 1
        time = capped_gpu_time(30.minutes)
        memory = '8g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_FOLDING {
        accelerator = 1
        time = capped_gpu_time(30.minutes)
        memory = '16g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        accelerator = 1
        time = capped_gpu_time(30.minutes)
        memory = '16g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_AFFINITY {
        accelerator = 1
        time = capped_gpu_time(30.minutes)
        memory = '16g'
        cpus = 2
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_ANALYSIS {
        time = capped_gpu_time(30.minutes)
        memory = '64g'
        cpus = 8
        clusterOptions = gpu_opts
    }

    withName: BOLTZGEN_FILTERING {
        time = capped_gpu_time(30.minutes)
        memory = '4g'
        cpus = 1
        clusterOptions = gpu_opts
    }

    withName: FOLDSEEK_DOWNLOAD_DB {
        executor = 'local'
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        time = 30.minutes
        memory = '4g'
        cpus = 2
    }

    withName: FOLDSEEK_LOCAL_SEARCH {
        time = 4.hours
        memory = '16g'
        cpus = 8
    }

    withName: FOLDSEEK_REMOTE_SEARCH {
        executor = 'local'
        time = 2.hours
        memory = '4g'
        cpus = 1
    }

    withName: FOLDSEEK_DOWNLOAD_CATH_NAMES {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
        errorStrategy = 'ignore'
    }

    withName: FOLDSEEK_ANNOTATE_CATH {
        time = 30.minutes
        memory = '4g'
        cpus = 2
        errorStrategy = 'ignore'
    }
}

apptainer {
    enabled = true
    autoMounts = true
    pullTimeout = 3.hours
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /data${scratch_bind}"
    envWhitelist = ['BOLTZ_CACHE']
}
