// Suppress "There's no process matching config selector: ..." warnings. This
// pipeline includes only the selected --method's workflow per run (see main.nf),
// so the `withName:` selectors for the other methods' processes match nothing.
// This flag is the documented way to silence those false warnings for
// conditionally-included processes. (Deprecated on Nextflow 25.10+, where the
// strict parser no longer emits the false warnings; harmless there.)
nextflow.enable.configProcessNamesValidation = false

manifest {
    name = 'nf-binder-design'
    author = '''Andrew Perry'''
    homePage = 'https://github.com/Australian-Protein-Design-Initiative/nf-binder-design'
    description = '''Protein binder design pipeline'''
    mainScript = 'main.nf'
    nextflowVersion = '!>=23.04.0, <26.10'
    version = '0.3.0'
    defaultBranch = 'main'
}

params {
    // GPU-related parameters used across multiple modules
    require_gpu = true
    gpu_devices = ''
    gpu_allocation_detect_process_regex = '(python.*/app/dl_binder_design/af2_initial_guess/predict\\.py|python.*/app/BindCraft/bindcraft\\.py|boltz predict|python.*/app/RFdiffusion/scripts/run_inference\\.py|rfd3 design|rf3 fold|run_germinal\\.py|protenix|chai)'
    // Referenced in modules/local/bindcraft/bindcraft.nf; must exist in config or Nextflow warns before workflow defaults run
    bindcraft_batch_size = 1

    // Defaults for the shared BOLTZ / MMSEQS_COLABFOLDSEARCH modules so every
    // entrypoint has them defined (fold.nf overrides / documents CLI knobs;
    // boltz_pulldown leaves these false = Boltz's own defaults). Boltz structure
    // format is a process input hardcoded by callers (fold.nf -> cif,
    // boltz_pulldown -> pdb).
    boltz_recycling = false
    boltz_batch_size = false
    boltz_sampling_steps = false
    boltz_seed = false
    colabfold_msa_publish_name = 'result'
    fold_predictions_dir = false

    // Germinal workflow defaults (workflows/germinal.nf may override)
    germinal_config = false
    germinal_pdb_dir = false
    germinal_experiment_name = 'germinal_design'
    germinal_n_traj = 10
    germinal_batch_size = 1
    germinal_max_passing_designs = 10000
    germinal_max_hallucinated_trajectories = 10000
    germinal_gpu_allocation_detect_process_regex = '(run_germinal\\.py|protenix|chai)'
}

process {
    executor = 'slurm'
    stageInMode = 'symlink'
    // errorStrategy = 'retry'
    maxRetries = 0
    cache = 'lenient'

    withName: GET_CONTIGS {
        executor = 'local'
    }

    withName: UNIQUE_ID {
        executor = 'local'
    }

    withName: RENUMBER_RESIDUES {
        executor = 'local'
    }

    withName: FILTER_DESIGNS {
        executor = 'local'
    }

    withName: RFD3_FILTER_DESIGNS {
        executor = 'local'
    }

    withName: AF2IG_SCORE_FILTER {
        executor = 'local'
    }

    withName: COMBINE_SCORES {
        executor = 'local'
    }
    
    withName: BOLTZ_PULLDOWN_REPORTING {
        executor = 'local'
    }

    withName: RFDIFFUSION {
        accelerator = 1
        time = 24.hours
        memory = '8g'
        cpus = 2
    }

    withName: RFDIFFUSION_PARTIAL {
        accelerator = 1
        time = 24.hours
        memory = '8g'
        cpus = 2
    }

    withName: RFDIFFUSION3 {
        accelerator = 1
        time = 24.hours
        memory = '32g'
        cpus = 2
    }

    withName: GENERATE_RFD3_CONFIG {
        executor = 'local'
    }

    withName: RFD3_STAGE_FOLDSEEK_CIF {
        executor = 'local'
    }

    withName: GENERATE_RF3_INPUT_JSON {
        executor = 'local'
    }

    withName: PREPARE_RF3_TEMPLATE {
        executor = 'local'
    }

    withName: MPNN {
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    withName: ROSETTAFOLD3 {
        accelerator = 1
        time = { 15.minutes * Math.max(1, (params.rf3_batch_size ?: 1) as int) }
        memory = '16g'
        cpus = 2
    }

    withName: RFD3_RMSD {
        executor = 'local'
    }

    withName: 'COMBINE_RFD3_SCORES' {
        executor = 'local'
    }

    withName: DL_BINDER_DESIGN_PROTEINMPNN {
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    withName: PDB_TO_FASTA {
        executor = 'local'
    }

    withName: AF2_INITIAL_GUESS {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 4
    }

    withName: ALPHAFOLD2_JACKHMMER_MSA {
        cpus = 8
        memory = '64.GB'
        time = 8.hours
    }

    withName: ALPHAFOLD2 {
        accelerator = 1
        cpus = 4
        memory = '64.GB'
        time = 2.hours
    }

    withName: CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: PARSE_BOLTZ_CONFIDENCE_JSON {
        executor = 'local'
    }

    withName: MMSEQS_COLABFOLDSEARCH {
        time = 4.hours
        memory = '32g'
        cpus = 8
    }

    withName: BOLTZ {
        accelerator = 1
        time = 2.hours
        memory = '16g'
        cpus = 2
    }

    withName: 'BOLTZ_PULLDOWN:BOLTZ' {
        accelerator = 1
        time = 2.hours
        memory = '16g'
        cpus = 2
    }

    withName: 'BOLTZ_.*' {
        accelerator = 1
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    // fold.nf (see plans/fold-nf-multi-method-folding.md) - new processes only;
    // MMSEQS_COLABFOLDSEARCH, ALPHAFOLD2*, BOLTZ selectors above are reused as-is.
    withName: COLABFOLD_A3M_TO_AF2_MSAS {
        executor = 'local'
    }

    withName: AF2_MSAS_TO_A3M {
        executor = 'local'
    }

    withName: FOLD_CREATE_BOLTZ_YAML {
        executor = 'local'
    }

    withName: FOLD_PARSE_BOLTZ_CONFIDENCE {
        executor = 'local'
    }

    // These fold.nf helpers are trivial local-executor tasks (YAML generation, a
    // one-row confidence parse), so cpus=1 is the right default. Their
    // fully-qualified names (BOLTZ_FOLD:...) are otherwise matched by the broad
    // `withName: 'BOLTZ_.*'` selector above, which sets cpus=2 - that overcommits
    // the Nextflow head and fails outright when the head has only 1 CPU. A
    // fully-qualified selector is applied last (highest specificity, like
    // BOLTZ_FOLD:BOLTZ), so these win.
    withName: 'BOLTZ_FOLD:FOLD_CREATE_BOLTZ_YAML' {
        executor = 'local'
        cpus = 1
    }
    withName: 'BOLTZ_FOLD:FOLD_CREATE_BOLTZ_YAML_COMPLEX' {
        executor = 'local'
        cpus = 1
    }
    withName: 'BOLTZ_FOLD:FOLD_PARSE_BOLTZ_CONFIDENCE' {
        executor = 'local'
        cpus = 1
    }

    // fold.nf score-TSV helpers: trivial JSON/pkl -> TSV parses (AF2 also runs
    // ipSAE) and the master merge. Local executor, cpus=1 - same rationale as
    // the Boltz helpers above.
    withName: 'ALPHAFOLD2:FOLD_SCORE_AF2' {
        executor = 'local'
        cpus = 1
    }
    withName: '.*:FOLD_PARSE_CONFIDENCE' {
        executor = 'local'
        cpus = 1
    }
    withName: 'FOLD_MERGE_SCORES' {
        executor = 'local'
        cpus = 1
    }

    withName: ENGENS_STAGE_STRUCTURE {
        executor = 'local'
    }

    withName: ENGENS {
        cpus = 4
        memory = '16g'
        time = 2.h
    }

    withName: 'BOLTZ_FOLD:BOLTZ' {
        accelerator = 1
        time = 2.hours
        memory = '16g'
        cpus = 2
        // NB: fold.nf's --boltz_* / --n_predictions flags are built inside the
        // BOLTZ module (modules/local/common/boltz.nf), NOT here as ext.args:
        // an ext.args closure on this qualified selector is silently dropped once
        // the m3 profile's broad `withName: BOLTZ` selector is layered in.
        // Samples/job come from meta.fold_batch_size when BOLTZ_FOLD fans out.
    }

    withName: GENERATE_RF3_FOLD_INPUT {
        executor = 'local'
    }

    withName: RF3_FOLD {
        accelerator = 1
        // Scale walltime by samples/job: --rf3_batch_size when set, else
        // --n_predictions (one big job), else the no-n_predictions default of 5.
        time = { 15.minutes * Math.max(1, (params.rf3_batch_size ?: params.n_predictions ?: 5) as int) }
        memory = '16g'
        cpus = 2
    }

    withName: GENERATE_PROTENIX_INPUT {
        executor = 'local'
    }

    // Selector uses the PROTENIX_FOLD_PROCESS include alias (see
    // subworkflows/local/protenix_fold.nf), not the process's own declared
    // name PROTENIX_FOLD - the wrapping subworkflow is also called
    // PROTENIX_FOLD (mirroring the plan's naming), so the process is aliased
    // on import to avoid a name collision within that file. withName matches
    // by simple (unqualified) process name, so this still selects correctly
    // regardless of which subworkflow calls it.
    withName: PROTENIX_FOLD_PROCESS {
        accelerator = 1
        time = 1.hours
        memory = '16g'
        cpus = 2
    }

    withName: BINDCRAFT_CREATE_SETTINGS {
        executor = 'local'
    }

    withName: BINDCRAFT {
        accelerator = 1
        time = 2.hours
        memory = '16g'
        cpus = 2
    }

    withName: /^(GERMINAL|GERMINAL_PROCESS)$/ {
        accelerator = 1
        time = 24.hours
        memory = '48g'
        cpus = 8
    }

    withName: GERMINAL_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_DESIGN {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
    }

    withName: BOLTZGEN_INVERSE_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '8g'
        cpus = 2
    }

    withName: BOLTZGEN_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
    }

    withName: BOLTZGEN_DESIGN_FOLDING {
        accelerator = 1
        time = 30.minutes
        memory = '16g'
        cpus = 2
    }

    withName: BOLTZGEN_MERGE {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
    }

    withName: BOLTZGEN_ANALYSIS {
        accelerator = 1
        time = 30.minutes
        memory = '8g' // '32g' // ?
        cpus = 2
    }

    withName: BOLTZGEN_FILTERING {
        time = 30.minutes
        memory = '4g'
        cpus = 1
    }

    // FoldSeek processes
    withName: FOLDSEEK_DOWNLOAD_DB {
        executor = 'local'
        time = 2.hours
        memory = '8g'
        cpus = 2
    }

    withName: FOLDSEEK_PREPARE_QUERIES {
        time = 30.minutes
        memory = '4g'
        cpus = 2
    }

    withName: FOLDSEEK_LOCAL_SEARCH {
        time = 4.hours
        memory = '16g'
        cpus = 8
    }

    withName: FOLDSEEK_REMOTE_SEARCH {
        executor = 'local'
        time = 2.hours
        memory = '4g'
        cpus = 1
    }

    withName: FOLDSEEK_DOWNLOAD_CATH_NAMES {
        executor = 'local'
        time = 30.minutes
        memory = '1g'
        cpus = 1
        errorStrategy = 'ignore'
    }

    withName: FOLDSEEK_ANNOTATE_CATH {
        time = 30.minutes
        memory = '4g'
        cpus = 2
        errorStrategy = 'ignore'
    }

    // This must be executed locally if you are not using a shared filesystem for the whole run (eg typical HPC)
    // since it requires input files to be available in paths outside the `work` directory.
    withName: PARSE_BOLTZGEN_CONFIG {
        executor = 'local'
    }
}

// Apptainer specific settings
apptainer {
    enabled = true

    autoMounts = true
    pullTimeout = 3.hours
    // --nv to enable NVIDIA GPU support
    // We add -B \$HOME to ensure the home directory is available (since Nextflow now uses --no-home by default)
    // The alternative is to set the NXF_APPTAINER_HOME_MOUNT=true environment variable
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME"
}

docker {
    enabled = false

    // --gpus all to enable NVIDIA GPU support
    // enabled = true
    runOptions = '--gpus all'
}

profiles {
    local {
        executor {
            name = 'local'
            // this should be overridden for workstations with multiple GPUs to allow more than
            // one simultaneous task.
            queueSize = 1
            pollInterval = '30 sec'
            submitRateLimit = '1/10sec'
        }
        process {
            executor = 'local'
            stageInMode = 'symlink'
            maxRetries = 0
            cache = 'lenient'
        }
    }
    slurm {
        executor {
            name = 'slurm'
            queueSize = 900
            pollInterval = '30 sec'
            queueStatInterval = '10m'
        }
        process {
            executor = 'slurm'
            stageInMode = 'symlink'
            // errorStrategy = 'retry'
            maxRetries = 0
            cache = 'lenient'
        }
    }
    hq {
        executor {
            name = 'hq'
            queueSize = 900
            pollInterval = '5 sec'
            submitRateLimit = '1/10sec'
        }
        process {
            executor = 'hq'
            stageInMode = 'symlink'
            maxRetries = 0
            cache = 'lenient'
        }
    }

    ////
    //   Platform-specific configurations - add additional HPC clusters and cloud platforms here
    ////

    m3 {
        includeConfig "${projectDir}/conf/platforms/m3.config"
    }
    m3_bdi {
        includeConfig "${projectDir}/conf/platforms/m3_bdi.config"
    }
    mlerp {
        includeConfig "${projectDir}/conf/platforms/mlerp.config"
    }
    rotibom_hyperqueue {
        includeConfig "${projectDir}/conf/platforms/rotibom_hyperqueue.config"
    }
    hyperqueue {
        includeConfig "${projectDir}/conf/platforms/hyperqueue.config"
    }
    nci_gadi {
        includeConfig "${projectDir}/conf/platforms/nci_gadi.config"
    }
    pawsey_setonix {
        includeConfig "${projectDir}/conf/platforms/pawsey_setonix.config"
    }
    spartan_a100 {
        includeConfig "${projectDir}/conf/platforms/spartan-a100.config"
    }
    spartan_l40s {
        includeConfig "${projectDir}/conf/platforms/spartan-l40s.config"
    }
}
