// Redeclare the existing default so this file's own withName closures below can resolve
// params.gpu_devices without Nextflow's "Unknown directive `params`" warning / "Unknown
// config attribute" error. --gpu_devices set on the CLI still overrides this as normal.
params {
    gpu_devices = ''
}

profiles {
    local {
        executor {
            name = 'local'
            queueSize = 1000
            pollInterval = '30 sec'
            // We can't submit tasks too quickly or our internal GPU allocation 
            // via find_available_gpu.py will fail.
            submitRateLimit = '1/10sec'
        }
        process {
            executor = 'local'
            stageInMode = 'symlink'
            // We retry on failure to catch occasional cases where the process fails due to OOM,
            // as a result of a failure to allocate a dedicated GPU to the task.
            maxRetries = 3
            cache = 'lenient'

            withName: RFDIFFUSION {
                maxForks = params.gpu_devices ? params.gpu_devices.split(',').size() : null
            }
            withName: RFDIFFUSION_PARTIAL {
                maxForks = params.gpu_devices ? params.gpu_devices.split(',').size() : null
            }
            withName: AF2_INITIAL_GUESS {
                maxForks = params.gpu_devices ? params.gpu_devices.split(',').size() : null
            }
            withName: BINDCRAFT {
                maxForks = params.gpu_devices ? params.gpu_devices.split(',').size() : null
            }
            withName: BOLTZ {
                maxForks = params.gpu_devices ? params.gpu_devices.split(',').size() : null
            }
        }
    }
}
