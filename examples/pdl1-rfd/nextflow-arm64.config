// ARM64 / NVIDIA GB10 (Blackwell) override config.
// Apptainer is not installed on this host, so switch to Docker, and override
// container images with arm64-native builds.
apptainer {
    enabled = false
}

docker {
    enabled = true
    // This host runs *rootless* Docker: container UID 0 is remapped to the invoking
    // host user (not root), and our host UID isn't in the rootless subuid range, so
    // `-u $(id -u):$(id -g)` fails with "cannot setuid to unmapped uid". Running as
    // UID 0 (root-in-container) is what correctly maps to the host user's files here.
    runOptions = '--gpus all -u 0:0'
}

process {
    withName: 'RFDIFFUSION|RFDIFFUSION_PARTIAL' {
        container = 'ghcr.io/australian-protein-design-initiative/containers/rfdiffusion:dgl2508_arm64'
        // The image bakes in ENTRYPOINT ["python3", ".../run_inference.py"];
        // Apptainer ignores container ENTRYPOINT entirely, but Docker doesn't, so
        // `bash .command.run` ends up passed as an argument to run_inference.py
        // instead of being executed directly.
        containerOptions = '--entrypoint ""'
    }
    withName: AF2_INITIAL_GUESS {
        container = 'ghcr.io/australian-protein-design-initiative/containers/af2_initial_guess:arm64_py310'
    }
    withName: 'DL_BINDER_DESIGN_PROTEINMPNN|SILENT_FROM_PDBS' {
        // SILENT_FROM_PDBS normally uses proteinmpnn_fastrelax, which has no arm64
        // build (no Dockerfile at all in ~/projects/containers) - proteinmpnn_dl_binder_design
        // is used in its place instead (per-user decision), same underlying
        // dl_binder_design/ProteinMPNN codebase.
        container = 'ghcr.io/australian-protein-design-initiative/containers/proteinmpnn_dl_binder_design:arm64_py310'
    }
    withName: 'GET_CONTIGS|RENUMBER_RESIDUES|AF2IG_SCORE_FILTER|FILTER_DESIGNS|COMBINE_SCORES|PDB_TO_FASTA|TRIM_TO_CONTIGS|RMSD4ALL|CREATE_BOLTZ_YAML|CREATE_BOLTZ_YAML_MONOMER|BOLTZ_PULLDOWN_REPORTING' {
        container = 'ghcr.io/australian-protein-design-initiative/containers/nf-binder-design-utils:0.1.7'
    }
    withName: BINDCRAFT_SCORING {
        container = 'ghcr.io/australian-protein-design-initiative/containers/bindcraft:nv-cuda13-arm64'
    }
}
