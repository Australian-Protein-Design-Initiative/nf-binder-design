// The AlphaFold2 database lives under /mnt/datasets, outside the m3 profile's
// autoMounts-covered paths, so bind it explicitly here (rather than in the
// pipeline-wide m3.config) to keep the mount tied to the DB path param and
// out of the global config.
params.af2_db_path = '/mnt/datasets/alphafold/alphafold_20240229'

// No M3 default local ColabFold DB path exists yet (see
// plans/fold-nf-multi-method-folding.md) - set these if you have your own
// colabfold_search-format uniref30/colabfold_envdb DBs, otherwise pass
// --use_remote_server true to use the ColabFold API instead.
// params.uniref30 = '/path/to/your/uniref30_db'
// params.colabfold_envdb = '/path/to/your/colabfold_envdb'

apptainer {
    // runOptions is a full string replacement, so the existing m3.config
    // options (--nv --cleanenv --env PYTHONNOUSERSITE=1 -B $HOME -B /scratch2
    // -B /fs04) are restated here alongside the AF2 DB bind mount.
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /scratch2 -B /fs04 -B ${params.af2_db_path} -B /mnt/reference/alphafold"
}
