// ARM64 / NVIDIA GB10 (Blackwell) override config.
// Apptainer is not installed on this host, so switch to Docker, and override
// container images with arm64-native builds.
apptainer {
    enabled = false
}

docker {
    enabled = true
    // This host runs *rootless* Docker: container UID 0 is remapped to the invoking
    // host user (not root), and our host UID isn't in the rootless subuid range, so
    // `-u $(id -u):$(id -g)` fails with "cannot setuid to unmapped uid". Running as
    // UID 0 (root-in-container) is what correctly maps to the host user's files here.
    runOptions = '--gpus all -u 0:0'
}

process {
    withName: 'BOLTZGEN_ANALYSIS|BOLTZGEN_DESIGN_FOLDING|BOLTZGEN_CHECK|BOLTZGEN_DESIGN|BOLTZGEN_INVERSE_FOLDING|BOLTZGEN_MERGE|BOLTZGEN_FILTERING|BOLTZGEN_AFFINITY|BOLTZGEN_FOLDING' {
        container = 'ghcr.io/australian-protein-design-initiative/containers/boltzgen:0.3.2_nv-cuda13-arm64'
        // The image bakes in ENTRYPOINT ["boltzgen"]; Apptainer ignores container
        // ENTRYPOINT entirely, but Docker doesn't, so `bash .command.run` ends up
        // passed as arguments to `boltzgen` instead of being executed directly.
        containerOptions = '--entrypoint ""'
    }
    // `boltzgen run` hangs indefinitely on GB10 (no CPU/GPU activity, no error) -
    // py-spy showed the main thread blocked waiting on a DataLoader worker stuck
    // forever inside torch.cdist. This is a fork()-after-threading-init deadlock:
    // DataLoader workers are forked after the parent process initializes an OpenMP/
    // BLAS thread pool, and this arm64 build's native threading backend deadlocks in
    // the forked child on its first native op - the amd64/MKL build apparently
    // doesn't hit this. --num_workers 0 avoids forking DataLoader workers entirely.
    // (Note: the pipeline's own --num_workers CLI param is silently dropped when set
    // to 0, since the module renders it as `num_workers ? "--num_workers N" : ""` and
    // Groovy treats 0 as falsy - so it must be forced here via ext.args instead.)
    // --use_kernels false is also set, disabling the cuequivariance/triton kernel
    // path, out of caution since it wasn't isolated from the num_workers fix.
    withName: 'BOLTZGEN_ANALYSIS|BOLTZGEN_DESIGN_FOLDING|BOLTZGEN_DESIGN|BOLTZGEN_INVERSE_FOLDING|BOLTZGEN_FILTERING|BOLTZGEN_AFFINITY|BOLTZGEN_FOLDING' {
        ext.args = '--use_kernels false --num_workers 0'
    }
}
