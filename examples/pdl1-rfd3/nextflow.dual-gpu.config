profiles {
    local {
        executor {
            name = 'local'
            // Allow CPU tasks (MPNN, MMseqs2, staging) alongside up to N GPU tasks.
            queueSize = 8
            pollInterval = '5 sec'
            // Stagger launches so find_available_gpu.py can see the other GPU's workload.
            // Faster than 1/10sec while still reducing startup races.
            submitRateLimit = '1/2sec'
        }
        process {
            executor = 'local'
            stageInMode = 'symlink'
            // We retry on failure to catch occasional cases where the process fails due to OOM,
            // as a result of a failure to allocate a dedicated GPU to the task.
            maxRetries = 3
            cache = 'lenient'

            withName: RFDIFFUSION3 {
                if (params.gpu_devices) {
                    maxForks = params.gpu_devices.split(',').size()
                }
            }
            withName: ROSETTAFOLD3 {
                if (params.gpu_devices) {
                    maxForks = params.gpu_devices.split(',').size()
                }
            }
            withName: BOLTZ_COMPARE_COMPLEX {
                if (params.gpu_devices) {
                    maxForks = params.gpu_devices.split(',').size()
                }
            }
            withName: BOLTZ_COMPARE_BINDER_MONOMER {
                if (params.gpu_devices) {
                    maxForks = params.gpu_devices.split(',').size()
                }
            }
        }
    }
}
