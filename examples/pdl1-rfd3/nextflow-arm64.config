// ARM64 / NVIDIA GB10 (Blackwell) override config.
// Apptainer is not installed on this host, so switch to Docker, and override
// container images with arm64-native builds.
apptainer {
    enabled = false
}

docker {
    enabled = true
    // This host runs *rootless* Docker: container UID 0 is remapped to the invoking
    // host user (not root), and our host UID isn't in the rootless subuid range, so
    // `-u $(id -u):$(id -g)` fails with "cannot setuid to unmapped uid". Running as
    // UID 0 (root-in-container) is what correctly maps to the host user's files here.
    runOptions = '--gpus all -u 0:0'
}

process {
    withName: 'RFDIFFUSION3|MPNN|ROSETTAFOLD3' {
        // Default uses the oras:// (Apptainer/SIF) reference; Docker needs a plain
        // pullable image reference. This -ngc2606 build bumps the base image from NGC
        // pytorch 25.01 to 26.06 - 25.01's NVRTC doesn't recognize GB10's sm_121
        // compute capability, causing RosettaFold3's bf16 erfinv op to fail with
        // "invalid value for --gpu-architecture"; 26.06 fixes this.
        container = 'ghcr.io/australian-protein-design-initiative/containers/rc-foundry:0.2.0_arm64-weights-ngc2606'
    }
    withName: 'RFD3_RMSD|PREPARE_RF3_TEMPLATE|RENAME_RF3_TEMPLATE_CHAINS|GENERATE_RF3_INPUT_JSON|COMBINE_RFD3_SCORES|FILTER_DESIGNS' {
        container = 'ghcr.io/australian-protein-design-initiative/containers/nf-binder-design-utils:0.1.7'
    }
}
