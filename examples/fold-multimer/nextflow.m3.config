// AF2 MULTIMER on M3 needs the 2021 DB snapshot (alphafold_20211129): unlike the
// default 20240229 monomer snapshot it ships the uniprot/ all-seqs pairing DB and
// pdb_seqres/ templates that AF2's multimer pipeline pairs species against.
//
// The 2021 snapshot's DB filenames differ from the 20240229 defaults, so the
// per-DB sub-paths are overridden here (all verified against the on-disk layout
// on 2026-07-23):
//   uniref30 -> uniclust30/uniclust30_2018_08/uniclust30_2018_08 (HHblits DB prefix)
//   mgnify   -> mgy_clusters_2018_12.fa (not 2022_05)
//   uniprot  -> uniprot/uniprot.fasta   pdb_seqres -> pdb_seqres/pdb_seqres.txt
params.af2_db_path = '/mnt/datasets/alphafold/alphafold_20211129'
params.af2_uniref30_subpath = 'uniclust30/uniclust30_2018_08/uniclust30_2018_08'
params.af2_mgnify_subpath = 'mgnify/mgy_clusters_2018_12.fa'
params.af2_uniprot_subpath = 'uniprot/uniprot.fasta'
params.af2_pdb_seqres_subpath = 'pdb_seqres/pdb_seqres.txt'
// The container's run_alphafold.py loads multimer_v3 model weights, which the
// 2021 snapshot lacks (it ships only v1 multimer params). --data_dir only
// locates params/, so read weights from the 20240229 snapshot (has
// params_model_*_multimer_v3.npz) while the genetic DBs stay on the 2021 one.
params.af2_data_dir = '/mnt/datasets/alphafold/alphafold_20240229'

apptainer {
    // runOptions is a full string replacement, so restate the m3.config options.
    // Bind the whole /mnt/datasets/alphafold so both the 2021 DB snapshot and the
    // 20240229 params snapshot are visible; the 2021 DB symlinks resolve into
    // /mnt/reference/alphafold, which is also bound.
    runOptions = "--nv --cleanenv --env PYTHONNOUSERSITE=1 -B \$HOME -B /scratch2 -B /fs04 -B /mnt/datasets/alphafold -B /mnt/reference/alphafold"
}
